<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- SafeWoman Brand Colors — basados en index.html -->
    <Color x:Key="BrandPrimary">#8B1A3A</Color>
    <Color x:Key="BrandDark">#6B0F2A</Color>
    <Color x:Key="BrandLight">#F9E8EC</Color>
    <Color x:Key="SosRed">#E53935</Color>
    <Color x:Key="SosDark">#B71C1C</Color>

    <!-- MAUI Default aliases (apuntando a la marca) -->
    <Color x:Key="Primary">#8B1A3A</Color>
    <Color x:Key="PrimaryDark">#6B0F2A</Color>
    <Color x:Key="PrimaryDarkText">#FFFFFF</Color>
    <Color x:Key="Secondary">#F9E8EC</Color>
    <Color x:Key="SecondaryDarkText">#8B1A3A</Color>
    <Color x:Key="Tertiary">#6B0F2A</Color>

    <!-- Backgrounds & Text -->
    <Color x:Key="BgMain">#FFFFFF</Color>
    <Color x:Key="BgSec">#F8F9FA</Color>
    <Color x:Key="Border">#E0E0E0</Color>
    <Color x:Key="TextMain">#212529</Color>
    <Color x:Key="TextMuted">#6C757D</Color>
    <Color x:Key="TextInverse">#FFFFFF</Color>

    <!-- Alias de colores requeridos por Styles.xaml (template MAUI) -->
    <Color x:Key="MidnightBlue">#6B0F2A</Color>
    <Color x:Key="OffBlack">#1C1C1E</Color>
    <Color x:Key="Magenta">#8B1A3A</Color>

    <!-- Generic -->
    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="Gray100">#E1E1E1</Color>
    <Color x:Key="Gray200">#C8C8C8</Color>
    <Color x:Key="Gray300">#ACACAC</Color>
    <Color x:Key="Gray400">#919191</Color>
    <Color x:Key="Gray500">#6E6E6E</Color>
    <Color x:Key="Gray600">#404040</Color>
    <Color x:Key="Gray900">#212121</Color>
    <Color x:Key="Gray950">#141414</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource BrandPrimary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource BrandLight}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource BrandDark}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>
    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}"/>
</ResourceDictionary>
