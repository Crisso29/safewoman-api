<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SafeWoman.Views.Contacto.ContactosPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:SafeWoman.ViewModels.Contacto"
    xmlns:models="clr-namespace:SafeWoman.Models"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">
        <Grid Grid.Row="0" BackgroundColor="{StaticResource BrandDark}" Padding="16,48,16,16">
            <Grid ColumnDefinitions="Auto,*">
                <Button Grid.Column="0" Text="←" BackgroundColor="#33FFFFFF" TextColor="White"
                        FontSize="18" WidthRequest="40" HeightRequest="40" CornerRadius="20"
                        Clicked="VolverClicked" />
                <VerticalStackLayout Grid.Column="1" Margin="16,0,0,0" VerticalOptions="Center">
                    <Label Text="Contactos de emergencia" TextColor="White" FontSize="17" FontAttributes="Bold" />
                    <Label Text="Máximo 5 contactos" TextColor="#CCF9E8EC" FontSize="12" />
                </VerticalStackLayout>
            </Grid>
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,24" Spacing="16">

                <!-- Agregar contacto -->
                <Border BackgroundColor="{StaticResource BgMain}" Stroke="{StaticResource Border}"
                        StrokeShape="RoundRectangle 16" Padding="16">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Agregar contacto" FontSize="14" FontAttributes="Bold" TextColor="{StaticResource BrandDark}" />
                        <Entry Text="{Binding NuevoNombre}" Placeholder="Nombre completo"
                               BackgroundColor="{StaticResource BgSec}" />
                        <Entry Text="{Binding NuevoTelefono}" Placeholder="Celular (9 dígitos)"
                               Keyboard="Telephone" MaxLength="9" BackgroundColor="{StaticResource BgSec}" />
                        <Button Text="+ Agregar" Command="{Binding AgregarCommand}"
                                BackgroundColor="{StaticResource BrandPrimary}" TextColor="White"
                                CornerRadius="10" FontAttributes="Bold" />
                    </VerticalStackLayout>
                </Border>

                <!-- Lista -->
                <Label Text="Mis contactos" FontSize="14" FontAttributes="Bold" TextColor="{StaticResource TextMain}" />

                <CollectionView ItemsSource="{Binding Contactos}" EmptyView="No tienes contactos de emergencia.">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:ContactoEmergenciaDto">
                            <Border BackgroundColor="{StaticResource BgMain}" Stroke="{StaticResource Border}"
                                    StrokeShape="RoundRectangle 12" Padding="16" Margin="0,0,0,10">
                                <Grid ColumnDefinitions="*,Auto">
                                    <VerticalStackLayout Grid.Column="0" Spacing="4">
                                        <Label Text="{Binding Nombre}" FontAttributes="Bold" FontSize="14"
                                               TextColor="{StaticResource TextMain}" />
                                        <Label Text="{Binding Telefono}" FontSize="13"
                                               TextColor="{StaticResource TextMuted}" />
                                    </VerticalStackLayout>
                                    <Image Grid.Column="1" Source="ic_trash.svg" WidthRequest="22" HeightRequest="22" VerticalOptions="Center">
                                        <Image.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ContactosViewModel}}, Path=EliminarCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Image.GestureRecognizers>
                                    </Image>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <ActivityIndicator IsRunning="{Binding IsBusy}" Color="{StaticResource BrandPrimary}"
                                   IsVisible="{Binding IsBusy}" />

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
