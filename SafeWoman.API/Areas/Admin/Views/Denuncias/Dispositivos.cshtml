@model IReadOnlyList<SafeWoman.Application.DTOs.Admin.AdminHuellaDto>
@{ ViewBag.Title = "Dispositivos"; }

@section Styles {
<style>
.sw-device-row { transition: background .12s; }
.sw-device-row:hover td { background: #fafafa; }
.sw-code {
    font-family: 'Cascadia Code', 'Consolas', monospace;
    font-size: .75rem; color: #4b5563;
    background: #f4f5f7; padding: .18rem .5rem;
    border-radius: 5px; letter-spacing: -.2px;
}
.sw-toggle-btn {
    display: inline-flex; align-items: center; gap: .3rem;
    padding: .3rem .7rem; border-radius: 7px;
    font-size: .75rem; font-weight: 600; cursor: pointer;
    border: 1.5px solid; transition: all .15s; background: transparent;
}
.sw-toggle-btn.bloquear { border-color: #fecaca; color: #dc2626; }
.sw-toggle-btn.bloquear:hover { background: #fef2f2; }
.sw-toggle-btn.desbloquear { border-color: #bbf7d0; color: #15803d; }
.sw-toggle-btn.desbloquear:hover { background: #f0fdf4; }
</style>
}

<div class="d-flex align-items-end justify-content-between mb-4">
    <div>
        <h1 style="font-size:22px;font-weight:700;margin:0 0 4px;letter-spacing:-.02em">Dispositivos</h1>
        <p style="font-size:13px;color:#6B7280;margin:0">
            @Model.Count dispositivo@(Model.Count != 1 ? "s" : "") · <b style="color:#dc2626">@Model.Count(h => h.Bloqueada)</b> bloqueado@(Model.Count(h => h.Bloqueada) != 1 ? "s" : "")
        </p>
    </div>
</div>

<div class="sw-card">
    <div class="table-responsive">
        <table class="sw-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Fingerprint</th>
                    <th>Estado</th>
                    <th>Primer uso</th>
                    <th>Último uso</th>
                    <th class="text-center">Denuncias</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="7">
                        <div class="sw-empty">
                            <div class="sw-empty-icon"><i class="bi bi-phone"></i></div>
                            <div class="fw-semibold" style="color:#374151">Sin dispositivos registrados</div>
                            <p>Los dispositivos aparecerán aquí al enviar denuncias anónimas.</p>
                        </div>
                    </td>
                </tr>
            }
            @foreach (var h in Model)
            {
                <tr class="sw-device-row">
                    <td style="font-size:.73rem;color:#d1d5db;font-weight:600">#@h.IdHuella</td>
                    <td>
                        <span class="sw-code">
                            @h.DeviceFingerprint[..Math.Min(20, h.DeviceFingerprint.Length)]…
                        </span>
                    </td>
                    <td>
                        @if (h.Bloqueada)
                        {
                            <span class="sw-badge" style="background:#fef2f2;color:#dc2626">
                                <span class="sw-dot" style="background:#dc2626"></span>Bloqueada
                            </span>
                        }
                        else
                        {
                            <span class="sw-badge sw-badge-activo">
                                <span class="sw-dot"></span>Activa
                            </span>
                        }
                    </td>
                    <td style="font-size:.8rem;color:#9ca3af;white-space:nowrap">
                        @h.FechaPrimerUso.ToLocalTime().ToString("dd/MM/yyyy")
                    </td>
                    <td style="font-size:.8rem;color:#9ca3af;white-space:nowrap">
                        @h.FechaUltimoUso.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                    </td>
                    <td class="text-center">
                        <span class="fw-semibold" style="font-size:.85rem">@h.TotalDenuncias</span>
                    </td>
                    <td>
                        <form asp-action="ToggleHuella" asp-controller="Denuncias" asp-area="Admin" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id"       value="@h.IdHuella" />
                            <input type="hidden" name="bloquear" value="@(!h.Bloqueada ? "true" : "false")" />
                            <button type="submit" class="sw-toggle-btn @(h.Bloqueada ? "desbloquear" : "bloquear")">
                                <i class="bi @(h.Bloqueada ? "bi-unlock" : "bi-ban")"></i>
                                @(h.Bloqueada ? "Desbloquear" : "Bloquear")
                            </button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
