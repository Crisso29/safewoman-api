<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@(ViewBag.Title != null ? ViewBag.Title + " — " : "")SafeWoman Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>
        :root {
            --brand:       #8B1A3A;
            --brand-dark:  #6B0F2A;
            --brand-light: #FDF2F4;
            --brand-mid:   #A52050;
            --sidebar-bg:  #1C0A12;
            --sidebar-w:   240px;
            --topbar-h:    64px;
            --radius:      12px;
            --border:      #F0EBED;
        }

        *, *::before, *::after { box-sizing: border-box; }

        body {
            font-family: 'Inter', 'Segoe UI', system-ui, -apple-system, sans-serif;
            background: #F8F6F7;
            color: #1A1A1A;
            margin: 0;
            -webkit-font-smoothing: antialiased;
        }

        /* ── Sidebar ─────────────────────────────────────────── */
        .sw-sidebar {
            position: fixed;
            top: 0; left: 0;
            width: var(--sidebar-w);
            height: 100vh;
            background: var(--sidebar-bg);
            display: flex;
            flex-direction: column;
            z-index: 200;
            box-shadow: 4px 0 24px rgba(0,0,0,.22);
        }

        /* Brand */
        .sw-brand {
            padding: 22px 20px 18px;
            display: flex; align-items: center; gap: 12px;
            border-bottom: 1px solid rgba(255,255,255,.08);
        }
        .sw-brand-logo {
            width: 38px; height: 38px; border-radius: 11px; background: var(--brand);
            display: flex; align-items: center; justify-content: center; flex-shrink: 0;
            box-shadow: 0 4px 10px rgba(139,26,58,0.4), inset 0 1px 0 rgba(255,255,255,0.18);
        }
        .sw-brand h6 {
            color: #fff; font-weight: 700; font-size: .94rem; margin: 0; letter-spacing: -0.01em; line-height: 1.1;
        }
        .sw-brand small { color: rgba(255,255,255,.5); font-size: .67rem; letter-spacing: 0.02em; }

        /* Nav */
        .sw-nav { padding: .5rem 0; flex: 1; overflow-y: auto; }
        .sw-nav::-webkit-scrollbar { width: 3px; }
        .sw-nav::-webkit-scrollbar-thumb { background: rgba(255,255,255,.12); border-radius: 3px; }

        .sw-nav-label {
            color: rgba(255,255,255,.38);
            font-size: .63rem; font-weight: 700;
            letter-spacing: 1.9px; text-transform: uppercase;
            padding: .85rem 20px .3rem;
        }

        .sw-nav-item { display: block; padding: 0 10px; }
        .sw-nav-link {
            display: flex; align-items: center; gap: 12px;
            padding: 10px 12px;
            color: rgba(255,255,255,.78);
            text-decoration: none; font-size: .813rem; font-weight: 500;
            border-radius: 8px; transition: all .15s ease;
            position: relative; margin-bottom: 2px;
        }
        .sw-nav-link svg { flex-shrink: 0; opacity: .8; transition: opacity .15s; }
        .sw-nav-link:hover {
            color: #fff; background: rgba(255,255,255,.06);
            transform: translateX(2px);
        }
        .sw-nav-link:hover svg { opacity: 1; }
        .sw-nav-link.active {
            color: #fff; background: var(--brand);
            font-weight: 600; padding-left: 14px;
        }
        .sw-nav-link.active svg { opacity: 1; }
        .sw-nav-link.active::before {
            content: '';
            position: absolute; left: 0; top: 9px; bottom: 9px;
            width: 3px; background: #fff;
            border-radius: 0 2px 2px 0;
        }

        /* Nav badge */
        .sw-nav-badge {
            position: relative; margin-left: auto;
            min-width: 22px; height: 18px; padding: 0 6px;
            background: #EF4444; color: #fff;
            font-size: .625rem; font-weight: 700; border-radius: 9px;
            display: inline-flex; align-items: center; justify-content: center;
        }
        .sw-nav-badge-ring {
            position: absolute; inset: 0; border-radius: 9px;
            background: #EF4444; opacity: 0.5;
            animation: swPulseRing 1.6s ease-out infinite;
        }

        /* User footer */
        .sw-user {
            margin: 12px 14px 16px;
            padding: 12px;
            background: rgba(255,255,255,.04);
            border: 1px solid rgba(255,255,255,.06);
            border-radius: 10px;
            display: flex; align-items: center; gap: 10px;
        }
        .sw-user-avatar {
            width: 36px; height: 36px; border-radius: 50%;
            background: linear-gradient(135deg, #C0395A, #8B1A3A);
            color: #fff; font-size: .8rem; font-weight: 700;
            display: flex; align-items: center; justify-content: center; flex-shrink: 0;
        }
        .sw-user-name {
            font-size: .78rem; font-weight: 600; line-height: 1.2;
            white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
        }
        .sw-user-role { font-size: .66rem; color: rgba(255,255,255,.5); margin-top: 2px; }
        .sw-user-logout {
            background: transparent; border: none; color: rgba(255,255,255,.5);
            padding: 6px; cursor: pointer; border-radius: 6px;
            display: flex; margin-left: auto; flex-shrink: 0;
            transition: all .15s;
        }
        .sw-user-logout:hover { background: rgba(255,255,255,.08); color: #fff; }

        /* ── Main ────────────────────────────────────────────── */
        .sw-main {
            margin-left: var(--sidebar-w);
            min-height: 100vh;
            display: flex; flex-direction: column;
        }

        /* Topbar */
        .sw-topbar {
            height: var(--topbar-h);
            background: #fff;
            border-bottom: 1px solid #EDE6E9;
            display: flex; align-items: center; justify-content: space-between;
            padding: 0 32px;
            position: sticky; top: 0; z-index: 100;
            flex-shrink: 0;
        }
        .sw-breadcrumb-path { display: flex; align-items: center; gap: 8px; font-size: .813rem; }
        .sw-breadcrumb-root { color: #9CA3AF; }
        .sw-breadcrumb-sep  { color: #D1D5DB; }
        .sw-breadcrumb-cur  { color: #1A1A1A; font-weight: 600; }

        .sw-topbar-right { display: flex; align-items: center; gap: 16px; }

        /* Bell button */
        .sw-notif-btn {
            width: 36px; height: 36px;
            background: #F8F4F6; border: 1px solid var(--border);
            border-radius: 8px; display: flex; align-items: center; justify-content: center;
            cursor: pointer; color: #6B7280; position: relative;
            transition: all .15s;
        }
        .sw-notif-btn:hover { background: var(--brand-light); color: var(--brand); border-color: #F4D4DC; }
        .sw-notif-dot {
            position: absolute; top: 6px; right: 6px;
            width: 7px; height: 7px;
            background: #EF4444; border-radius: 50%; border: 1.5px solid #fff;
            display: none;
        }
        .sw-notif-dot.show { display: block; }

        /* Clock */
        .sw-clock {
            display: flex; align-items: center; gap: 6px;
            font-size: .813rem; color: #6B7280;
            font-variant-numeric: tabular-nums;
        }

        /* Online pill */
        .sw-online-pill {
            display: inline-flex; align-items: center; gap: 6px;
            padding: 5px 10px;
            background: #ECFDF5; border: 1px solid #D1FAE5;
            border-radius: 20px; font-size: .75rem; font-weight: 600; color: #047857;
        }
        .sw-online-dot {
            width: 7px; height: 7px; background: #10B981;
            border-radius: 50%; flex-shrink: 0;
        }

        /* SOS Banner */
        .sw-sos-banner {
            display: none; background: #FEF2F2; border: 1px solid #FECACA;
            color: #B91C1C; padding: 5px 12px; border-radius: 20px;
            font-size: .75rem; font-weight: 700; align-items: center; gap: 6px;
        }
        .sw-sos-banner.show { display: inline-flex; }

        /* Toggle (mobile) */
        .sw-toggle { display: none; }

        /* Content */
        .sw-content {
            padding: 28px 32px; flex: 1;
            animation: swPageIn .3s cubic-bezier(.4,0,.2,1) both;
        }

        /* Alerts (TempData) */
        .sw-alert-wrap { padding: 0 32px; }

        /* ── Animations ───────────────────────────────────────── */
        @@keyframes swPageIn {
            from { opacity: 0; transform: translateY(10px); }
            to   { opacity: 1; }
        }
        @@keyframes swFadeIn {
            from { opacity: 0; transform: translateY(6px); }
            to   { opacity: 1; }
        }
        @@keyframes swPulseRing {
            0%   { transform: scale(0.85); opacity: 0.6; }
            100% { transform: scale(2.6); opacity: 0; }
        }
        @@keyframes swPulseDot {
            0%,100% { opacity: 1; }
            50%      { opacity: 0.35; }
        }
        @@keyframes swPulseScale {
            0%,100% { transform: scale(1); }
            50%      { transform: scale(1.15); }
        }

        /* Stagger entrance */
        .sw-content > * { animation: swFadeIn .35s cubic-bezier(.4,0,.2,1) both; }
        .sw-content > *:nth-child(1) { animation-delay: .04s; }
        .sw-content > *:nth-child(2) { animation-delay: .09s; }
        .sw-content > *:nth-child(3) { animation-delay: .14s; }
        .sw-content > *:nth-child(4) { animation-delay: .19s; }

        /* ── Stat Cards ───────────────────────────────────────── */
        .sw-stat {
            background: #fff; border: 1px solid var(--border);
            border-radius: var(--radius); padding: 18px 20px;
            box-shadow: 0 1px 2px rgba(28,10,18,.04);
            transition: transform .2s, box-shadow .2s; cursor: default;
        }
        .sw-stat:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(0,0,0,.09); }
        .sw-stat-icon {
            width: 38px; height: 38px; border-radius: 10px;
            display: flex; align-items: center; justify-content: center; font-size: 1.1rem;
        }
        .sw-stat-val  { font-size: 1.9rem; font-weight: 800; line-height: 1; letter-spacing: -.025em; color: #1A1A1A; }
        .sw-stat-lbl  { font-size: .78rem; color: #6B7280; font-weight: 500; }
        .sw-stat-delta { font-size: .72rem; font-weight: 600; color: #059669; display: flex; align-items: center; gap: 4px; }

        /* ── Cards ────────────────────────────────────────────── */
        .sw-card {
            background: #fff; border-radius: var(--radius);
            box-shadow: 0 1px 2px rgba(28,10,18,.04);
            border: 1px solid var(--border); overflow: hidden;
        }
        .sw-card-header {
            padding: .9rem 1.25rem; border-bottom: 1px solid #F3F4F6;
            display: flex; align-items: center; justify-content: space-between;
        }
        .sw-card-title { font-weight: 700; font-size: .88rem; color: #1A1A1A; margin: 0; }

        /* ── Tables ───────────────────────────────────────────── */
        .sw-table { width: 100%; border-collapse: collapse; font-size: .845rem; }
        .sw-table thead th {
            background: #FCFAFB; border-bottom: 1px solid #F3EEF0;
            padding: 11px 14px; font-weight: 700; font-size: .7rem;
            text-transform: uppercase; letter-spacing: .7px; color: #9CA3AF; white-space: nowrap;
        }
        .sw-table tbody td { padding: .75rem 14px; border-bottom: 1px solid #F8F5F6; vertical-align: middle; }
        .sw-table tbody tr:last-child td { border-bottom: none; }
        .sw-table tbody tr { transition: background .12s; }
        .sw-table tbody tr:hover td { background: #FAFAFA; }

        /* ── Badges ───────────────────────────────────────────── */
        .sw-badge {
            display: inline-flex; align-items: center; gap: .3rem;
            padding: .22rem .6rem; border-radius: 20px;
            font-size: .7rem; font-weight: 700; letter-spacing: .2px;
        }
        .sw-dot {
            display: inline-block; width: 6px; height: 6px;
            border-radius: 50%; flex-shrink: 0;
        }
        .sw-badge-activa      { background: #fde8ec; color: var(--brand); }
        .sw-badge-activa .sw-dot { background: var(--brand); }
        .sw-badge-cancelada   { background: #f3f4f6; color: #6b7280; }
        .sw-badge-cancelada .sw-dot { background: #9ca3af; }
        .sw-badge-pendiente   { background: #fffbeb; color: #b45309; }
        .sw-badge-pendiente .sw-dot { background: #f59e0b; }
        .sw-badge-enrevision  { background: #eff6ff; color: #1d4ed8; }
        .sw-badge-enrevision .sw-dot { background: #3b82f6; }
        .sw-badge-atendida    { background: #f0fdf4; color: #15803d; }
        .sw-badge-atendida .sw-dot { background: #22c55e; }
        .sw-badge-desestimada { background: #fdf2f8; color: #86198f; }
        .sw-badge-desestimada .sw-dot { background: #d946ef; }
        .sw-badge-activo      { background: #f0fdf4; color: #15803d; }
        .sw-badge-activo .sw-dot { background: #22c55e; }
        .sw-badge-inactivo    { background: #f3f4f6; color: #6b7280; }
        .sw-badge-inactivo .sw-dot { background: #9ca3af; }
        /* Estados de Denuncia */
        .sw-badge-enproceso   { background: #eff6ff; color: #1d4ed8; }
        .sw-badge-enproceso .sw-dot { background: #3b82f6; }
        .sw-badge-archivada   { background: #f3f4f6; color: #6b7280; }
        .sw-badge-archivada .sw-dot { background: #9ca3af; }

        /* Live pulse badge */
        .sw-live-badge {
            display: inline-flex; align-items: center; gap: .4rem;
            padding: .28rem .7rem; background: #fde8ec; color: var(--brand);
            border-radius: 20px; font-size: .72rem; font-weight: 700;
        }
        .sw-live-dot { position: relative; width: 7px; height: 7px; }
        .sw-live-dot::before {
            content: ''; position: absolute; inset: 0; background: var(--brand); border-radius: 50%;
        }
        .sw-live-dot::after {
            content: ''; position: absolute; inset: -3px; background: var(--brand); border-radius: 50%;
            opacity: 0; animation: swPulseRing 1.8s ease-in-out infinite;
        }

        /* ── Buttons ─────────────────────────────────────────── */
        .sw-btn {
            display: inline-flex; align-items: center; gap: .4rem;
            padding: .45rem 1rem; border-radius: 8px;
            font-size: .82rem; font-weight: 600; cursor: pointer;
            transition: all .15s; border: none; text-decoration: none;
            font-family: inherit;
        }
        .sw-btn-brand { background: var(--brand); color: #fff; }
        .sw-btn-brand:hover { background: var(--brand-mid); color: #fff; transform: translateY(-1px); }
        .sw-btn-ghost { background: transparent; color: #6b7280; border: 1px solid #E5E7EB; }
        .sw-btn-ghost:hover { background: #F9FAFB; color: #374151; border-color: #D1D5DB; }

        /* ── Search ───────────────────────────────────────────── */
        .sw-search {
            display: flex; align-items: center; gap: .5rem;
            background: #F4F5F7; border-radius: 8px; padding: .4rem .75rem;
            border: 1.5px solid transparent; transition: border-color .15s, background .15s;
        }
        .sw-search:focus-within { background: #fff; border-color: var(--brand); box-shadow: 0 0 0 3px rgba(139,26,58,.08); }
        .sw-search i { color: #9ca3af; font-size: .9rem; }
        .sw-search input { border: none; background: transparent; outline: none; font-size: .84rem; color: #1A1A1A; width: 180px; font-family: inherit; }
        .sw-search input::placeholder { color: #9ca3af; }

        /* ── Avatar ───────────────────────────────────────────── */
        .sw-avt { display: inline-flex; align-items: center; justify-content: center; border-radius: 50%; font-weight: 700; flex-shrink: 0; }

        /* ── Empty state ──────────────────────────────────────── */
        .sw-empty { text-align: center; padding: 3.5rem 1rem; color: #9ca3af; }
        .sw-empty-icon {
            width: 52px; height: 52px; background: #F4F5F7; border-radius: 14px;
            display: inline-flex; align-items: center; justify-content: center;
            font-size: 1.4rem; margin-bottom: .85rem; color: #c9cdd3;
        }
        .sw-empty p { font-size: .85rem; margin: .3rem 0 0; }

        /* ── Toggle button (bloquear/activar) ────────────────── */
        .sw-toggle-btn {
            display: inline-flex; align-items: center; gap: .3rem;
            padding: .3rem .7rem; border-radius: 7px; font-size: .75rem;
            font-weight: 600; cursor: pointer; border: 1.5px solid;
            transition: all .15s; background: transparent; font-family: inherit;
        }
        .sw-toggle-btn.desactivar { border-color: #fecaca; color: #dc2626; }
        .sw-toggle-btn.desactivar:hover { background: #fef2f2; }
        .sw-toggle-btn.activar   { border-color: #bbf7d0; color: #15803d; }
        .sw-toggle-btn.activar:hover   { background: #f0fdf4; }

        /* ── Responsive ───────────────────────────────────────── */
        @@media (max-width: 992px) {
            .sw-sidebar { transform: translateX(-100%); transition: transform .25s cubic-bezier(.4,0,.2,1); }
            .sw-sidebar.open { transform: translateX(0); }
            .sw-main { margin-left: 0; }
            .sw-toggle { display: flex !important; }
            .sw-content { padding: 20px 16px; }
            .sw-topbar { padding: 0 16px; }
        }
    </style>
    @RenderSection("Styles", required: false)
</head>
<body>

<!-- Sidebar -->
<aside class="sw-sidebar" id="sidebar">

    <div class="sw-brand">
        <div class="sw-brand-logo">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"></path>
                <path d="M12 16.5 C 8.2 14.2, 7 12.4, 7 10.6 A 2.5 2.5 0 0 1 12 9.6 A 2.5 2.5 0 0 1 17 10.6 C 17 12.4, 15.8 14.2, 12 16.5 Z" fill="#fff" stroke="none"></path>
            </svg>
        </div>
        <div style="min-width:0">
            <h6>SafeWoman</h6>
            <small>Panel de Administración</small>
        </div>
    </div>

    <nav class="sw-nav">
        <div class="sw-nav-label">Principal</div>

        <div class="sw-nav-item">
            <a class="sw-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")"
               href="@Url.Action("Index", "Dashboard", new { area = "Admin" })">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="7" height="9" x="3" y="3" rx="1"></rect><rect width="7" height="5" x="14" y="3" rx="1"></rect><rect width="7" height="9" x="14" y="12" rx="1"></rect><rect width="7" height="5" x="3" y="16" rx="1"></rect></svg>
                <span>Dashboard</span>
            </a>
        </div>
        <div class="sw-nav-item">
            <a class="sw-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Alertas" ? "active" : "")"
               href="@Url.Action("Index", "Alertas", new { area = "Admin" })" id="nav-alertas">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 12a5 5 0 0 1 5-5v0a5 5 0 0 1 5 5v6H7v-6Z"></path><path d="M5 20a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v2H5v-2Z"></path><path d="M21 12h1"></path><path d="M2 12h1"></path><path d="M12 2v1"></path></svg>
                <span>Alertas SOS</span>
                <span class="sw-nav-badge" id="nav-sos-count" style="display:none">
                    <span class="sw-nav-badge-ring"></span>
                    <span style="position:relative">!</span>
                </span>
            </a>
        </div>

        <div class="sw-nav-label mt-1">Gestión</div>

        <div class="sw-nav-item">
            <a class="sw-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Denuncias" ? "active" : "")"
               href="@Url.Action("Index", "Denuncias", new { area = "Admin" })">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="8" x2="14" y1="13" y2="13"></line><line x1="8" x2="14" y1="17" y2="17"></line><line x1="8" x2="10" y1="9" y2="9"></line></svg>
                <span>Denuncias</span>
            </a>
        </div>
        <div class="sw-nav-item">
            <a class="sw-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Victimas" ? "active" : "")"
               href="@Url.Action("Index", "Victimas", new { area = "Admin" })">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M22 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                <span>Víctimas</span>
            </a>
        </div>
        <div class="sw-nav-item">
            <a class="sw-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Logs" ? "active" : "")"
               href="@Url.Action("Index", "Logs", new { area = "Admin" })">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path><path d="M3 3v5h5"></path><path d="M12 7v5l4 2"></path></svg>
                <span>Auditoría</span>
            </a>
        </div>
    </nav>

    @{
        var userName    = User.Identity?.Name ?? "Admin";
        var userInitials = userName.Length >= 2
            ? (userName[0].ToString() + (userName.Contains(" ") ? userName.Split(' ').Last()[0].ToString() : userName[1].ToString())).ToUpper()
            : userName[0].ToString().ToUpper();
    }
    <div class="sw-user">
        <div class="sw-user-avatar">@userInitials</div>
        <div style="flex:1;min-width:0;color:#fff">
            <div class="sw-user-name">@userName</div>
            <div class="sw-user-role">Administrador</div>
        </div>
        <a href="@Url.Action("Logout", "Auth", new { area = "Admin" })" class="sw-user-logout" title="Cerrar sesión"
           onclick="return confirm('¿Cerrar sesión?')">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" x2="9" y1="12" y2="12"></line></svg>
        </a>
    </div>
</aside>

<!-- Overlay (mobile) -->
<div id="overlay" onclick="toggleSidebar()"
     style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:199;backdrop-filter:blur(2px)"></div>

<!-- Main -->
<div class="sw-main">

    <!-- Topbar -->
    <header class="sw-topbar">
        <div class="d-flex align-items-center gap-3">
            <button class="sw-toggle btn p-1 border-0" onclick="toggleSidebar()" style="background:transparent">
                <i class="bi bi-list fs-4 text-secondary"></i>
            </button>
            <div class="sw-breadcrumb-path">
                <span class="sw-breadcrumb-root">SafeWoman Admin</span>
                <span class="sw-breadcrumb-sep">/</span>
                <span class="sw-breadcrumb-cur">@(ViewBag.Title ?? "Dashboard")</span>
            </div>
        </div>
        <div class="sw-topbar-right">
            <span class="sw-sos-banner" id="sos-live-banner">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path><path d="M13.73 21a2 2 0 0 1-3.46 0"></path></svg>
                ¡Alerta SOS activa!
            </span>
            <button class="sw-notif-btn" id="sw-notif-btn" title="Alertas SOS">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"></path><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"></path></svg>
                <span class="sw-notif-dot" id="sw-notif-dot"></span>
            </button>
            <div class="sw-clock">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                <span id="sw-clock">@DateTime.Now.ToString("dd/MM/yyyy HH:mm")</span>
            </div>
            <div class="sw-online-pill" id="sw-online-pill" style="display:none">
                <span class="sw-online-dot"></span>
                <span>En línea</span>
            </div>
        </div>
    </header>

    @if (TempData["Mensaje"] != null)
    {
        <div class="sw-alert-wrap pt-3">
            <div class="alert alert-success alert-dismissible fade show d-flex align-items-center gap-2 border-0 shadow-sm" style="border-radius:var(--radius);animation:swFadeIn .3s ease" role="alert">
                <i class="bi bi-check-circle-fill text-success flex-shrink-0"></i>
                <span>@TempData["Mensaje"]</span>
                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
            </div>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="sw-alert-wrap pt-3">
            <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center gap-2 border-0 shadow-sm" style="border-radius:var(--radius);animation:swFadeIn .3s ease" role="alert">
                <i class="bi bi-exclamation-circle-fill text-danger flex-shrink-0"></i>
                <span>@TempData["Error"]</span>
                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
            </div>
        </div>
    }

    <div class="sw-content">
        @RenderBody()
    </div>
</div>

@RenderSection("Modals", required: false)

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@8.0.0/dist/browser/signalr.min.js"></script>
<script>
    // Sidebar toggle
    function toggleSidebar() {
        const s = document.getElementById('sidebar');
        const o = document.getElementById('overlay');
        s.classList.toggle('open');
        o.style.display = s.classList.contains('open') ? 'block' : 'none';
    }

    // Live clock
    (function tick() {
        const el = document.getElementById('sw-clock');
        if (el) {
            const n = new Date();
            el.textContent = n.toLocaleDateString('es-PE') + ' ' + n.toLocaleTimeString('es-PE', {hour:'2-digit',minute:'2-digit'});
        }
        setTimeout(tick, 30000);
    })();

    // Bell → Alertas SOS
    const notifBtn = document.getElementById('sw-notif-btn');
    if (notifBtn) notifBtn.addEventListener('click', () => { window.location.href = '/Admin/Alertas'; });

    // SignalR
    const conn = new signalR.HubConnectionBuilder()
        .withUrl("/hubs/sos", { transport: signalR.HttpTransportType.WebSockets | signalR.HttpTransportType.LongPolling })
        .withAutomaticReconnect([0, 2000, 5000, 10000])
        .configureLogging(signalR.LogLevel.Warning)
        .build();

    conn.on("NuevaAlertaSos", (data) => {
        // SOS banner
        const banner = document.getElementById("sos-live-banner");
        if (banner) banner.classList.add('show');

        // Nav badge
        const badge = document.getElementById("nav-sos-count");
        if (badge) {
            badge.style.display = "inline-flex";
            const numEl = badge.querySelector('span[style*="position:relative"]') || badge.lastElementChild;
            if (numEl) numEl.textContent = (parseInt(numEl.textContent) || 0) + 1;
        }

        // Bell dot
        const dot = document.getElementById("sw-notif-dot");
        if (dot) dot.classList.add('show');

        if (typeof onNuevaAlerta === "function") onNuevaAlerta(data);

        if (Notification.permission === "granted")
            new Notification("⚠️ SafeWoman — Alerta SOS", {
                body: `${data.nombreVictima} · ${data.telefono}`,
                icon: "/favicon.ico"
            });
        else if (Notification.permission !== "denied")
            Notification.requestPermission();
    });

    conn.on("AlertaCancelada", (data) => {
        if (typeof onAlertaCancelada === "function") onAlertaCancelada(data);
    });

    conn.start()
        .then(() => {
            const pill = document.getElementById("sw-online-pill");
            if (pill) pill.style.display = "inline-flex";
        })
        .catch(e => console.warn("[SignalR]", e.message));
</script>
@RenderSection("Scripts", required: false)
</body>
</html>
